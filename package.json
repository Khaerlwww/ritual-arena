{
  "name": "ritual-arena",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "lint": "tsc --noEmit",
    "check:stale-js": "node scripts/check-stale-js.cjs",
    "prebuild": "node scripts/check-stale-js.cjs",
    "build": "vite build",
    "test": "hardhat test",
    "compile": "hardhat compile",
    "deploy:arena": "hardhat run scripts/deploy/arena.js --network ritualTestnet",
    "deploy:dependent": "hardhat run scripts/deploy/dependent-contracts.js --network ritualTestnet",
    "deploy:ritual-v5": "node scripts/deploy/ritual-v5.js",
    "deploy:training:post-p0": "node scripts/deploy/redeploy-training-post-p0.mjs",
    "deploy:packmanager:v8": "node scripts/deploy/deploy-v8-supply.mjs",
    "seed:packmanager:v8": "node scripts/seed/seed-v8-supply.mjs",
    "matchmaking": "ts-node scripts/admin/matchmaking-keeper.ts",
    "verify:wiring": "node scripts/verify/wiring.js",
    "verify:ap-support": "node scripts/verify/ap-support.mjs",
    "verify:forge": "node scripts/verify/forge.mjs",
    "admin:rewire-arena": "node scripts/admin/rewire-arena.js",
    "audit:prod": "npm audit --omit=dev --audit-level=moderate"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.0.2",
    "@vitejs/plugin-react": "4.3.4",
    "autoprefixer": "10.4.20",
    "ethers": "^6.16.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "0.468.0",
    "postcss": "^8.5.15",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwindcss": "3.4.17",
    "viem": "^2.51.3",
    "vite": "^6.4.2"
  },
  "overrides": {
    "cookie": "0.7.2",
    "glob": "^13.0.0",
    "inflight": "npm:lru-cache@^10.2.0",
    "lodash.isequal": "npm:react-fast-compare@^3.2.2",
    "serialize-javascript": "7.0.5",
    "tmp": "0.2.7",
    "undici": "^5.28.4",
    "uuid": "11.1.1",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.1",
    "@types/react": "18.3.17",
    "@types/react-dom": "18.3.5",
    "chai": "^4.5.0",
    "dotenv": "^17.4.2",
    "hardhat": "^2.28.6",
    "ts-node": "^10.9.2",
    "typescript": "5.7.2"
  }
}
