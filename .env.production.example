# .env.production.example — public production template
#
# These values would go to Vercel Environment Variables (Project Settings).
# This file is for public consumption — only contains placeholders.
# NEVER commit real values here.

# ─── Frontend (VITE_ prefix required for Vite) ──────────────────────────
VITE_RITUAL_CHAIN_ID=1979
VITE_RITUAL_RPC_URL=https://rpc.ritualfoundation.org
VITE_RITUAL_EXPLORER_URL=https://explorer.ritualfoundation.org

VITE_RITUAL_AP_ADDRESS=0x_YOUR_DEPLOYED_RITUAL_AP_ADDRESS
VITE_RITUAL_IDENTITY_REGISTRY_ADDRESS=0x_YOUR_DEPLOYED_IDENTITY_REGISTRY_ADDRESS
VITE_RITUAL_IDENTITY_CARD_ADDRESS=0x_YOUR_DEPLOYED_IDENTITY_CARD_ADDRESS
VITE_RITUAL_ACHIEVEMENT_REGISTRY_ADDRESS=0x_YOUR_DEPLOYED_ACHIEVEMENT_REGISTRY_ADDRESS
VITE_RITUAL_TRAINING_ADDRESS=0x_YOUR_DEPLOYED_TRAINING_ADDRESS
VITE_RITUAL_ARENA_ADDRESS=0x_YOUR_DEPLOYED_ARENA_ADDRESS
VITE_RITUAL_STAKING_ADDRESS=0x_YOUR_DEPLOYED_STAKING_ADDRESS
VITE_RITUAL_PACK_NFT_ADDRESS=0x_YOUR_DEPLOYED_PACK_NFT_ADDRESS
VITE_RITUAL_PACK_MANAGER_ADDRESS=0x_YOUR_DEPLOYED_PACK_MANAGER_ADDRESS
VITE_RITUAL_MARKETPLACE_ADDRESS=0x_YOUR_DEPLOYED_MARKETPLACE_ADDRESS
VITE_RITUAL_CARD_BURNER_ADDRESS=0x_YOUR_DEPLOYED_CARD_BURNER_ADDRESS

# ─── Forge attestation endpoint (optional override) ─────────────────────
# Defaults to /api/forge if not set.
# VITE_ATTESTATION_URL=/api/forge
