# .env.example — public template
#
# Copy to `.env` for local dev. NEVER commit `.env` to git.
# All real values (private keys, RPC URLs with credentials) go in `.env` only.
# This file is for public consumption — only contains placeholders.

# ─── Chain config (PUBLIC values) ─────────────────────────────────────────
VITE_RITUAL_CHAIN_ID=1979
VITE_RITUAL_RPC_URL=https://rpc.ritualfoundation.org
VITE_RITUAL_EXPLORER_URL=https://explorer.ritualfoundation.org

# ─── Contract addresses (PUBLIC values, fill in for your target network) ─
# V11 testnet deploy. These are public on-chain addresses.
VITE_RITUAL_AP_ADDRESS=0x0000000000000000000000000000000000000000
VITE_RITUAL_IDENTITY_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
VITE_RITUAL_IDENTITY_CARD_ADDRESS=0x0000000000000000000000000000000000000000
VITE_RITUAL_ACHIEVEMENT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
VITE_RITUAL_TRAINING_ADDRESS=0x0000000000000000000000000000000000000000
VITE_RITUAL_ARENA_ADDRESS=0x0000000000000000000000000000000000000000
VITE_RITUAL_STAKING_ADDRESS=0x0000000000000000000000000000000000000000
VITE_RITUAL_PACK_NFT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_RITUAL_PACK_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
VITE_RITUAL_MARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000
VITE_RITUAL_CARD_BURNER_ADDRESS=0x0000000000000000000000000000000000000000
